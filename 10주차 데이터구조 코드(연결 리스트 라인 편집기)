Node* get_entry(int pos) { 
    Node* p = head; 
    int i; 
    if (pos < 0) 
        return NULL; 
    for (i = 0; i < pos; i++) { 
        if (p == NULL) 
            return NULL; 
            p = p->link; 
    } 
    return p; 
} 
// 리스트에 저장된 단어 개수 반환 
int size(void) { 
    Node* p = head; 
    int count = 0; 
    while (p != NULL) { 
          count++; 
          p = p->link; 
    } 
    return count; 
} 
