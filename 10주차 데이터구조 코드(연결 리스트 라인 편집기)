//위치 번호로 단어 변경
void replace(int pos, Element val){
    Node* node;

    if(pos < 0 || pos >= size()){
        printf("변경 위치 오류입니다.\n");
        return;
    }

    node = get_entry(pos);

    if(node != NULL)
        node -> date = val;
}

